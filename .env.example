# The deterministic demo works without an API key.
# Reauthenticate the OpenAI Platform connector before provisioning a key.
OPENAI_API_KEY=
COURSEFUZZ_MODEL=gpt-5.6-sol
COURSEFUZZ_DB_PATH=coursefuzz.db
COURSEFUZZ_ARTIFACT_DIR=data/artifacts
# Optional deployment auth. JSON maps tenant IDs to distinct random tokens (24+ chars).
# When omitted, the server labels itself local-demo and uses one local tenant.
COURSEFUZZ_ACCESS_KEYS_JSON=
# Keep 1 behind HTTPS. Set 0 only for local HTTP testing of the browser session.
COURSEFUZZ_COOKIE_SECURE=1
# Optional: fine-grained token with Contents:write and Pull requests:write on target repos.
COURSEFUZZ_GITHUB_TOKEN=
