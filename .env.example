# The deterministic demo works without an API key.
# Reauthenticate the OpenAI Platform connector before provisioning a key.
OPENAI_API_KEY=
COURSEFUZZ_MODEL=gpt-5.6-sol
# End-to-end proof budget; validated at startup and bounded to 30-120 seconds.
COURSEFUZZ_ANALYSIS_DEADLINE_SECONDS=60
COURSEFUZZ_DB_PATH=coursefuzz.db
COURSEFUZZ_ARTIFACT_DIR=data/artifacts
# Optional deployment auth. JSON maps tenant IDs to distinct random tokens (24+ chars).
# When omitted, the server labels itself local-demo and uses one local tenant.
COURSEFUZZ_ACCESS_KEYS_JSON=
# Optional independent reviewer credential. It adds the `judge-review` tenant without replacing
# or exposing the existing tenant-key map. Share the value only through the submission test field.
COURSEFUZZ_JUDGE_ACCESS_TOKEN=
# Keep 1 behind HTTPS. Set 0 only for local HTTP testing of the browser session.
COURSEFUZZ_COOKIE_SECURE=1
# Beta fallback: fine-grained token with Contents:write and Pull requests:write on target repos.
COURSEFUZZ_GITHUB_TOKEN=
# Independent fail-closed repository scope for the beta token.
COURSEFUZZ_GITHUB_ALLOWED_REPOS=
# Round-2 multi-workspace path: GitHub App credentials replace the shared token. Configure all
# three values together. The JSON maps tenant IDs to exact repository/installation-ID maps, for
# example {"course-a":{"owner/autograder":12345}}.
COURSEFUZZ_GITHUB_APP_ID=
COURSEFUZZ_GITHUB_APP_PRIVATE_KEY=
COURSEFUZZ_GITHUB_INSTALLATIONS_JSON=
# Self-serve onboarding: the GitHub App webhook signing secret. When set (with the App ID and
# private key), POST /api/github/webhook ingests signed installation callbacks so workspaces are
# learned dynamically instead of via the static installations JSON.
COURSEFUZZ_GITHUB_WEBHOOK_SECRET=
# Bind a workspace to its installation over the API (POST /api/github/installations/claim). Kept
# off by default: enable only where the caller's GitHub identity is verified, since binding by raw
# installation ID is otherwise guessable. Repository listing (GET /api/github/repositories) is
# always available and read-only.
COURSEFUZZ_ENABLE_SELF_SERVE_CLAIM=0
# GitHub OAuth app (user-to-server) credentials. When set, GET /api/github/login -> /api/github/
# callback verifies the caller owns the installation before binding it — the safe, always-on
# self-serve path that does not need the unverified claim flag above. The redirect URI must match
# the OAuth app registration and end with /api/github/callback (derived from the request if unset).
COURSEFUZZ_GITHUB_OAUTH_CLIENT_ID=
COURSEFUZZ_GITHUB_OAUTH_CLIENT_SECRET=
COURSEFUZZ_GITHUB_OAUTH_REDIRECT_URI=
